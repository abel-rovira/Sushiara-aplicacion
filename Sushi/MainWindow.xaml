<Window x:Class="Sushi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shushiara"
        Height="1336"
        Width="1280"
        MinHeight="720"
        MinWidth="1040"
        Background="#F7F7F7"
        FontFamily="Arial">
    <Window.Resources>
        <SolidColorBrush x:Key="Rojo" Color="#B91C1C"/>
        <SolidColorBrush x:Key="RojoOscuro" Color="#8F1515"/>
        <SolidColorBrush x:Key="Negro" Color="#111111"/>
        <SolidColorBrush x:Key="Carbon" Color="#1B1B1B"/>
        <SolidColorBrush x:Key="Gris" Color="#666666"/>
        <SolidColorBrush x:Key="Borde" Color="#D8D8D8"/>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource Rojo}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Rojo}"/>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource Rojo}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Rojo}"/>
        </Style>

        <Style x:Key="TextInput" TargetType="TextBox">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="#CFCFCF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ComboInput" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="#CFCFCF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PanelBox" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Borde}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <DataTemplate x:Key="ProductTemplate">
            <Border Background="White"
                    BorderBrush="{StaticResource Borde}"
                    BorderThickness="1"
                    Margin="0,0,0,12">
                <Grid MinHeight="154">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#E8E8E8" BorderBrush="{StaticResource Borde}" BorderThickness="0,0,1,0">
                        <Image Source="{Binding UrlImagen}" Stretch="UniformToFill"/>
                    </Border>
                    <Grid Grid.Column="1" Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <WrapPanel VerticalAlignment="Top">
                            <TextBlock Text="{Binding Nombre}" FontSize="18" FontWeight="Black" Foreground="Black"/>
                            <Border Background="{StaticResource Rojo}" Padding="7,3" Margin="10,0,0,0" Visibility="{Binding VisibilidadEtiqueta}">
                                <TextBlock Text="{Binding Etiqueta}" Foreground="White" FontSize="11" FontWeight="Black"/>
                            </Border>
                            <Border Background="#DC2626" Padding="7,3" Margin="8,0,0,0" Visibility="{Binding VisibilidadPicante}">
                                <TextBlock Text="{Binding TextoPicante}" Foreground="White" FontSize="11" FontWeight="Black"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding Descripcion}"
                                   Foreground="{StaticResource Gris}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,10"/>
                        <Grid Grid.Row="2">
                            <TextBlock Text="{Binding TextoPrecio}" FontWeight="Black" FontSize="15" VerticalAlignment="Center"/>
                            <Button Content="ANADIR"
                                    Tag="{Binding}"
                                    Click="AddProduct_Click"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource OutlineButton}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CategoryGroupTemplate">
            <StackPanel>
                <Grid Margin="0,28,0,14">
                <TextBlock Text="{Binding Nombre}"
                               FontSize="25"
                               FontWeight="Black"/>
                <TextBlock Text="{Binding TextoCantidad}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Gris}"
                               FontWeight="Bold"/>
                </Grid>
                <Border Height="3" Background="{StaticResource Negro}" Margin="0,-10,0,14"/>
                <ItemsControl ItemsSource="{Binding Productos}" ItemTemplate="{StaticResource ProductTemplate}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="CartTemplate">
            <Border BorderBrush="#DEDEDE" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="104"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Nombre}" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding TextoLinea}" Foreground="{StaticResource Gris}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="-" Tag="{Binding}" Click="Decrease_Click" Width="30" Padding="0" Background="#EEEEEE" BorderBrush="#CFCFCF"/>
                        <TextBlock Text="{Binding Cantidad}" Width="32" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                        <Button Content="+" Tag="{Binding}" Click="Increase_Click" Width="30" Padding="0" Background="#EEEEEE" BorderBrush="#CFCFCF"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#111111" BorderBrush="#B91C1C" BorderThickness="0,0,0,4" Padding="24,12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="SHUSHIARA" Foreground="White" FontSize="28" FontWeight="Black"/>
                    <TextBlock Text="Migracion escritorio C# WPF" Foreground="#BBBBBB" FontSize="12" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Sushi tradicional con alma moderna" Foreground="White" FontWeight="Bold" Margin="0,0,24,0"/>
                    <TextBlock Text="Carrer de la Mar 24, Valencia" Foreground="#CCCCCC"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Background="#F7F7F7">
            <TabItem Header="Inicio">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Height="520">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#111111" Offset="0"/>
                                    <GradientStop Color="#1B1B1B" Offset="0.55"/>
                                    <GradientStop Color="#8F1515" Offset="1"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="860">
                                <TextBlock Text="Sushi tradicional con alma moderna" Foreground="#DDFFFFFF" FontWeight="Black" TextAlignment="Center"/>
                                <TextBlock Text="Fresh is&#x0A;Boring" Foreground="White" FontSize="92" FontWeight="Black" TextAlignment="Center" LineHeight="88"/>
                                <TextBlock Text="La revolucion del sushi tradicional en Shushiara. Reservas en local, pedidos a domicilio, recogida y gestion interna en una aplicacion de escritorio."
                                           Foreground="#DDFFFFFF" FontSize="20" TextAlignment="Center" TextWrapping="Wrap" Margin="0,22,0,0"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,32,0,0">
                                    <Button Content="HACER PEDIDO" Style="{StaticResource PrimaryButton}" Click="GoPedido_Click" Margin="0,0,12,0"/>
                                    <Button Content="RESERVAR MESA" Style="{StaticResource OutlineButton}" Click="GoReserva_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="50,54">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource PanelBox}" Margin="0,0,16,0">
                                <StackPanel>
                                    <TextBlock Text="QUIENES SOMOS" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                                    <TextBlock Text="Pescado fresco, tecnica japonesa y una experiencia directa." FontSize="38" FontWeight="Black" TextWrapping="Wrap" Margin="0,10,0,18"/>
                                    <TextBlock Text="Shushiara es un restaurante de sushi pensado para disfrutar en el local y tambien en casa. La migracion conserva carta, carrito, pedidos, reservas y panel interno en C#."
                                               Foreground="{StaticResource Gris}" FontSize="17" TextWrapping="Wrap" LineHeight="28"/>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Column="1" Margin="16,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource PanelBox}" Margin="0,0,12,12">
                                    <StackPanel>
                                        <TextBlock Text="4,8/5" FontSize="36" FontWeight="Black"/>
                                        <TextBlock Text="Valoracion media" Foreground="{StaticResource Gris}" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource PanelBox}" Margin="12,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="30-45" FontSize="36" FontWeight="Black"/>
                                        <TextBlock Text="Minutos entrega" Foreground="{StaticResource Gris}" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource PanelBox}" Margin="0,12,12,0">
                                    <StackPanel>
                                        <TextBlock Text="12,00 EUR" FontSize="32" FontWeight="Black"/>
                                        <TextBlock Text="Pedido minimo" Foreground="{StaticResource Gris}" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBox}" Margin="12,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="00:00" FontSize="36" FontWeight="Black"/>
                                        <TextBlock Text="Viernes y sabado" Foreground="{StaticResource Gris}" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Border Background="#111111" Padding="50,44">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="HORARIOS" Foreground="{StaticResource Rojo}" FontWeight="Black"/>
                                    <TextBlock Text="Abiertos todos los dias" Foreground="White" FontSize="30" FontWeight="Black"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Lunes a jueves" Foreground="#BBBBBB" FontWeight="Bold"/>
                                    <TextBlock Text="13:00 - 16:00 / 20:00 - 23:30" Foreground="White" FontSize="18" FontWeight="Black"/>
                                    <TextBlock Text="Viernes y sabado" Foreground="#BBBBBB" FontWeight="Bold" Margin="0,18,0,0"/>
                                    <TextBlock Text="13:00 - 16:30 / 20:00 - 00:00" Foreground="White" FontSize="18" FontWeight="Black"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Domingo" Foreground="#BBBBBB" FontWeight="Bold"/>
                                    <TextBlock Text="13:00 - 16:00 / 20:00 - 23:00" Foreground="White" FontSize="18" FontWeight="Black"/>
                                    <TextBlock Text="Contacto" Foreground="#BBBBBB" FontWeight="Bold" Margin="0,18,0,0"/>
                                    <TextBlock Text="600 123 456 - ara@gmail.com" Foreground="White" FontSize="18" FontWeight="Black"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Pedido">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Height="306">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#111111" Offset="0"/>
                        <GradientStop Color="#0E0E0E" Offset="0.55"/>
                        <GradientStop Color="#050505" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid Margin="50,34">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="530"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="CARTA ONLINE" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                        <TextBlock Text="PEDIDO A&#x0A;DOMICILIO"
                                   Foreground="White"
                                   FontSize="74"
                                   FontWeight="Black"
                                   LineHeight="76"/>
                        <TextBlock Text="Elige sushi, ramen, sopas, noodles, postres y bebidas. Cocina japonesa preparada al momento."
                                   Foreground="#DDFFFFFF"
                                   FontSize="18"
                                   Width="660"
                                   TextWrapping="Wrap"
                                   Margin="0,20,0,0"/>
                    </StackPanel>

                    <Grid Grid.Column="1" Height="86" VerticalAlignment="Bottom" Background="#F5F5F5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="18" VerticalAlignment="Center">
                            <TextBlock Text="ENTREGA" Foreground="{StaticResource Gris}" FontSize="12" FontWeight="Black"/>
                            <TextBlock Text="30-45 min" FontWeight="Black" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" BorderBrush="{StaticResource Borde}" BorderThickness="1,0,1,0">
                            <StackPanel Margin="18" VerticalAlignment="Center">
                                <TextBlock Text="MINIMO" Foreground="{StaticResource Gris}" FontSize="12" FontWeight="Black"/>
                                <TextBlock Text="12,00 EUR" FontWeight="Black" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Column="2" Margin="18" VerticalAlignment="Center">
                            <TextBlock Text="VALORACION" Foreground="{StaticResource Gris}" FontSize="12" FontWeight="Black"/>
                            <TextBlock Text="4,8/5" FontWeight="Black" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="50,48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="196"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="306"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="CATEGORIAS" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black" Margin="0,0,0,16"/>
                    <ItemsControl x:Name="CategoriesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Tag="{Binding}"
                                        Click="CategoryButton_Click"
                                        HorizontalContentAlignment="Left"
                                        Margin="0,0,0,8"
                                        Background="White"
                                        BorderBrush="{StaticResource Borde}"
                                        Foreground="#222222"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="24,0">
                    <Grid Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="MENU COMPLETO" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                            <TextBlock Text="Nuestra carta" FontSize="31" Foreground="Black"/>
                        </StackPanel>
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource TextInput}"
                                 Width="360"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Buscar sushi, combo, bebida..."/>
                    </Grid>
                    <ItemsControl x:Name="GroupsList" ItemTemplate="{StaticResource CategoryGroupTemplate}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource PanelBox}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="TU CARRITO" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                                    <TextBlock Text="Pedido" FontSize="25"/>
                                </StackPanel>
                                <Border Width="34" Height="34" Background="{StaticResource Negro}" HorizontalAlignment="Right">
                                    <TextBlock x:Name="CartCountText" Text="0" Foreground="White" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ItemsControl x:Name="CartItemsList" ItemTemplate="{StaticResource CartTemplate}"/>
                            <TextBlock x:Name="EmptyCartText" Text="El carrito esta vacio." Foreground="{StaticResource Gris}" Margin="0,0,0,14"/>
                            <Border Height="2" Background="{StaticResource Negro}" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Subtotal"/>
                                <TextBlock x:Name="SubtotalText" Text="0,00 EUR" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Envio"/>
                                <TextBlock x:Name="DeliveryText" Text="0,00 EUR" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Total" FontSize="19" FontWeight="Black"/>
                                <TextBlock x:Name="TotalText" Text="0,00 EUR" HorizontalAlignment="Right" FontSize="19" FontWeight="Black"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBox}" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="DATOS DE ENTREGA" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                            <TextBlock Text="Finalizar" FontSize="25" Margin="0,2,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="DeliveryRadio" Content="A domicilio" IsChecked="True" Checked="DeliveryMode_Changed" FontWeight="Bold"/>
                                <RadioButton x:Name="PickupRadio" Grid.Column="1" Content="Recogida" Checked="DeliveryMode_Changed" FontWeight="Bold"/>
                            </Grid>

                            <TextBlock Text="Nombre"/>
                            <TextBox x:Name="NameBox" Style="{StaticResource TextInput}" Margin="0,4,0,12"/>
                            <TextBlock Text="Telefono"/>
                            <TextBox x:Name="PhoneBox" Style="{StaticResource TextInput}" Margin="0,4,0,12"/>
                            <TextBlock Text="Direccion"/>
                            <TextBox x:Name="AddressBox" Style="{StaticResource TextInput}" Margin="0,4,0,12"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Text="Fecha"/>
                                    <DatePicker x:Name="DateBox" MinHeight="42" Margin="0,4,0,0" SelectedDateChanged="DateBox_SelectedDateChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Hora"/>
                                    <ComboBox x:Name="HourBox" Style="{StaticResource ComboInput}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Pago"/>
                            <ComboBox x:Name="PaymentBox" Style="{StaticResource ComboInput}" Margin="0,4,0,12">
                                <ComboBoxItem Content="Tarjeta"/>
                                <ComboBoxItem Content="Bizum"/>
                                <ComboBoxItem Content="Efectivo"/>
                            </ComboBox>
                            <Border Background="#F7F7F7" BorderBrush="{StaticResource Borde}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="PAGO SIMULADO" Foreground="{StaticResource Rojo}" FontSize="12" FontWeight="Black"/>
                                    <TextBlock Text="No se realiza ningun cargo real." FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Notas"/>
                            <TextBox x:Name="NotesBox" Style="{StaticResource TextInput}" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,16"/>
                            <Button Content="ENVIAR PEDIDO" Style="{StaticResource PrimaryButton}" Click="SubmitOrder_Click"/>
                            <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontWeight="Bold" Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Reservas">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Height="280">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#111111" Offset="0"/>
                                    <GradientStop Color="#1B1B1B" Offset="0.65"/>
                                    <GradientStop Color="#8F1515" Offset="1"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Grid Margin="50,34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="520"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Bottom">
                                    <TextBlock Text="RESERVA ONLINE" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                                    <TextBlock Text="MESA EN&#x0A;SHUSHIARA" Foreground="White" FontSize="68" FontWeight="Black" LineHeight="70"/>
                                    <TextBlock Text="Ven a disfrutar sushi fresco en sala, terraza o barra. Reserva tu mesa en segundos."
                                               Foreground="#DDFFFFFF" FontSize="18" Width="620" TextWrapping="Wrap" Margin="0,16,0,0"/>
                                </StackPanel>
                                <Grid Grid.Column="1" Height="86" VerticalAlignment="Bottom" Background="#F5F5F5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="18" VerticalAlignment="Center">
                                        <TextBlock Text="VALORACION" Foreground="{StaticResource Gris}" FontSize="12" FontWeight="Black"/>
                                        <TextBlock Text="4,8/5" FontWeight="Black" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" BorderBrush="{StaticResource Borde}" BorderThickness="1,0,1,0">
                                        <StackPanel Margin="18" VerticalAlignment="Center">
                                            <TextBlock Text="AMBIENTE" Foreground="{StaticResource Gris}" FontSize="12" FontWeight="Black"/>
                                            <TextBlock Text="Local japones" FontWeight="Black" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="2" Margin="18" VerticalAlignment="Center">
                                        <TextBlock Text="ZONA" Foreground="{StaticResource Gris}" FontSize="12" FontWeight="Black"/>
                                        <TextBlock Text="Sala y terraza" FontWeight="Black" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>

                        <Grid Margin="50,48">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.85*"/>
                                <ColumnDefinition Width="1.15*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource PanelBox}" Margin="0,0,18,0">
                                <StackPanel>
                                    <TextBlock Text="TU MESA" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                                    <TextBlock Text="Una experiencia tranquila para comer sushi bien." FontSize="38" FontWeight="Black" TextWrapping="Wrap" Margin="0,8,0,18"/>
                                    <TextBlock Text="Mesas para comidas, cenas y celebraciones. Barra sushi para ver la preparacion en directo. Terraza disponible segun clima y aforo. Confirmacion telefonica de la reserva."
                                               Foreground="{StaticResource Gris}" FontSize="17" TextWrapping="Wrap" LineHeight="28"/>
                                    <Border Background="#F7F7F7" BorderBrush="{StaticResource Borde}" BorderThickness="1" Padding="16" Margin="0,24,0,0">
                                        <StackPanel>
                                            <TextBlock Text="RESERVA SIN PAGO PREVIO" Foreground="{StaticResource Rojo}" FontWeight="Black"/>
                                            <TextBlock Text="Solo guardamos tus datos para confirmar la mesa. No se cobra nada al reservar." TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource PanelBox}">
                                <StackPanel>
                                    <TextBlock Text="DATOS DE RESERVA" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                                    <TextBlock Text="Reservar mesa" FontSize="34" FontWeight="Black" Margin="0,2,0,18"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Nombre"/>
                                            <TextBox x:Name="ReservationNameBox" Style="{StaticResource TextInput}" Margin="0,4,0,12"/>
                                            <TextBlock Text="Email"/>
                                            <TextBox x:Name="ReservationEmailBox" Style="{StaticResource TextInput}" Margin="0,4,0,12"/>
                                            <TextBlock Text="Fecha"/>
                                            <DatePicker x:Name="ReservationDateBox" MinHeight="42" Margin="0,4,0,12" SelectedDateChanged="ReservationDateBox_SelectedDateChanged"/>
                                            <TextBlock Text="Personas"/>
                                            <TextBox x:Name="ReservationPeopleBox" Text="2" Style="{StaticResource TextInput}" Margin="0,4,0,12"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Telefono"/>
                                            <TextBox x:Name="ReservationPhoneBox" Style="{StaticResource TextInput}" Margin="0,4,0,12"/>
                                            <TextBlock Text="Zona"/>
                                            <ComboBox x:Name="ReservationZoneBox" Style="{StaticResource ComboInput}" Margin="0,4,0,12">
                                                <ComboBoxItem Content="Sala"/>
                                                <ComboBoxItem Content="Terraza"/>
                                                <ComboBoxItem Content="Barra sushi"/>
                                            </ComboBox>
                                            <TextBlock Text="Hora"/>
                                            <ComboBox x:Name="ReservationHourBox" Style="{StaticResource ComboInput}" Margin="0,4,0,12"/>
                                            <TextBlock Text="Ocasion"/>
                                            <TextBox x:Name="ReservationOccasionBox" Style="{StaticResource TextInput}" Margin="0,4,0,12"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Notas"/>
                                    <TextBox x:Name="ReservationNotesBox" Style="{StaticResource TextInput}" Height="86" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,18"/>
                                    <Button Content="ENVIAR RESERVA" Style="{StaticResource PrimaryButton}" Click="SubmitReservation_Click"/>
                                    <TextBlock x:Name="ReservationMessageText" TextWrapping="Wrap" FontWeight="Bold" Margin="0,14,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Administracion">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="50,48">
                        <TextBlock Text="ACCESO INTERNO" Foreground="{StaticResource Rojo}" FontSize="13" FontWeight="Black"/>
                        <TextBlock Text="Panel de pedidos y reservas" FontSize="42" FontWeight="Black" Margin="0,4,0,24"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource PanelBox}" Margin="0,0,12,22">
                                <StackPanel>
                                    <TextBlock Text="PEDIDOS" Foreground="{StaticResource Gris}" FontWeight="Black"/>
                                    <TextBlock x:Name="AdminOrderCountText" Text="0" FontSize="42" FontWeight="Black"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource PanelBox}" Margin="12,0,12,22">
                                <StackPanel>
                                    <TextBlock Text="RESERVAS" Foreground="{StaticResource Gris}" FontWeight="Black"/>
                                    <TextBlock x:Name="AdminReservationCountText" Text="0" FontSize="42" FontWeight="Black"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource PanelBox}" Margin="12,0,0,22">
                                <StackPanel>
                                    <TextBlock Text="ESTADO" Foreground="{StaticResource Gris}" FontWeight="Black"/>
                                    <TextBlock Text="Simulado" FontSize="42" FontWeight="Black"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource PanelBox}" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Pedidos recibidos" FontSize="28" FontWeight="Black" Margin="0,0,0,14"/>
                                    <ItemsControl x:Name="AdminOrdersList"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource PanelBox}" Margin="14,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Reservas recibidas" FontSize="28" FontWeight="Black" Margin="0,0,0,14"/>
                                    <ItemsControl x:Name="AdminReservationsList"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
